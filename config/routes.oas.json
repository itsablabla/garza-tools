{
  "openapi": "3.1.0",
  "info": {
    "version": "1.0.0",
    "title": "GARZA Tools API"
  },
  "paths": {
    "/mcp": {
      "post": {
        "summary": "MCP Server",
        "description": "Model Context Protocol server endpoint. AI agents connect here to discover and invoke GARZA Tools as MCP tools.",
        "operationId": "mcp-server",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "mcpServerHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "name": "garza-tools",
              "version": "1.0.0",
              "operations": [
                {
                  "file": "./config/routes.oas.json",
                  "id": "get-all-todos"
                },
                {
                  "file": "./config/routes.oas.json",
                  "id": "create-todo"
                },
                {
                  "file": "./config/routes.oas.json",
                  "id": "update-todo"
                },
                {
                  "file": "./config/routes.oas.json",
                  "id": "delete-todo"
                }
              ]
            }
          }
        },
        "responses": {
          "200": {
            "description": "MCP JSON-RPC response"
          }
        },
        "tags": ["MCP"]
      }
    },
    "/todos": {
      "get": {
        "summary": "Get all todos",
        "description": "Retrieves a complete list of all todo items from the system. Returns all todos regardless of completion status or owner.",
        "responses": {
          "200": {
            "description": "A list of todos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Todo"
                  }
                }
              }
            }
          }
        },
        "operationId": "get-all-todos",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://todo.zuplo.io"
            }
          },
          "mcp": {
            "type": "tool",
            "name": "get_all_todos",
            "description": "Retrieves a complete list of all todo items. Use this to see all tasks in the system.",
            "annotations": {
              "readOnlyHint": true
            }
          }
        },
        "tags": ["Todo"]
      },
      "post": {
        "summary": "Create a new todo",
        "description": "Creates a new todo item with the provided details. The todo will be assigned a unique ID automatically.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTodo"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Todo created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Todo"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body"
          }
        },
        "operationId": "create-todo",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://todo.zuplo.io"
            }
          },
          "mcp": {
            "type": "tool",
            "name": "create_todo",
            "description": "Creates a new todo item. Provide a title and userId; completed defaults to false.",
            "annotations": {
              "destructiveHint": false,
              "idempotentHint": false
            }
          }
        },
        "tags": ["Todo"]
      }
    },
    "/todos/{id}": {
      "put": {
        "summary": "Update a todo",
        "description": "Updates an existing todo item by its unique identifier. You can modify title, completion status, and user assignment.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "description": "The numeric todo ID to update"
            },
            "description": "The todo ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTodo"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Todo updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Todo"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body"
          },
          "404": {
            "description": "Todo not found"
          }
        },
        "operationId": "update-todo",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://todo.zuplo.io"
            }
          },
          "mcp": {
            "type": "tool",
            "name": "update_todo",
            "description": "Updates an existing todo item by ID. Can change title, completed status, or userId.",
            "annotations": {
              "idempotentHint": true
            }
          }
        },
        "tags": ["Todo"]
      },
      "delete": {
        "summary": "Delete a todo",
        "description": "Permanently removes a todo item from the system using its unique identifier. This operation cannot be undone.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "description": "The numeric todo ID to delete"
            },
            "description": "The todo ID"
          }
        ],
        "responses": {
          "204": {
            "description": "Todo deleted successfully"
          },
          "404": {
            "description": "Todo not found"
          }
        },
        "operationId": "delete-todo",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://todo.zuplo.io"
            }
          },
          "mcp": {
            "type": "tool",
            "name": "delete_todo",
            "description": "Permanently deletes a todo item by ID. This cannot be undone.",
            "annotations": {
              "destructiveHint": true,
              "idempotentHint": true
            }
          }
        },
        "tags": ["Todo"]
      }
    }
  },
  "components": {
    "schemas": {
      "Todo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "The unique todo ID"
          },
          "title": {
            "type": "string",
            "description": "The todo title or task description"
          },
          "completed": {
            "type": "boolean",
            "description": "Whether the todo has been completed"
          },
          "userId": {
            "type": "integer",
            "description": "The ID of the user who owns this todo"
          }
        },
        "required": ["id", "title", "completed", "userId"]
      },
      "CreateTodo": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "The todo title or task description"
          },
          "completed": {
            "type": "boolean",
            "description": "Whether the todo is already completed",
            "default": false
          },
          "userId": {
            "type": "integer",
            "description": "The ID of the user who owns this todo"
          }
        },
        "required": ["title", "userId"]
      },
      "UpdateTodo": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Updated todo title or task description"
          },
          "completed": {
            "type": "boolean",
            "description": "Updated completion status"
          },
          "userId": {
            "type": "integer",
            "description": "Updated user ID"
          }
        }
      }
    }
  }
}
